{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "effect-claudecode",
  "version": "0.1.0",
  "description": "Effect runtime and bindings around Claude Code plugin primitives — write Claude Code plugins in a maximally Effect-first way.",
  "keywords": [
    "claude",
    "claude-code",
    "effect",
    "hooks",
    "mcp",
    "plugin",
    "settings",
    "skills",
    "subagents"
  ],
  "homepage": "https://github.com/mpsuesser/effect-claudecode#readme",
  "bugs": {
    "url": "https://github.com/mpsuesser/effect-claudecode/issues"
  },
  "license": "MIT",
  "author": "Marc Suesser",
  "repository": {
    "type": "git",
    "url": "https://github.com/mpsuesser/effect-claudecode.git"
  },
  "type": "module",
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true });\" && bun run build:ts && bun run build:types:rewrite",
    "build:ts": "tsc -p tsconfig.build.json",
    "build:types:rewrite": "bun ./scripts/rewrite-dts-relative-imports.mjs",
    "check": "bun run test && bun run typecheck && bun run build && bun run pack:dry-run",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "bun run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run check"
  },
  "sideEffects": false,
  "devDependencies": {
    "@effect/platform-bun": "4.0.0-beta.46",
    "@effect/platform-node-shared": "4.0.0-beta.46",
    "@effect/vitest": "4.0.0-beta.46",
    "@types/bun": "^1.3.10",
    "effect": "4.0.0-beta.46",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "effect": "^4.0.0-beta.46",
    "@effect/platform-node-shared": "^4.0.0-beta.46"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "bun@1.3.11",
  "dependencies": {
    "yaml": "^2.8.3"
  }
}
